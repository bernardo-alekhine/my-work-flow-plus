[flake8]
max-line-length = 120

# Essential ignores for Black compatibility
# E203: Whitespace before ':' (Black uses this in slices)
# W503: Line break occurred before a binary operator (Black style)
extend-ignore = E203, W503

exclude =
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    env,
    .tox

# Standard strict limit
max-complexity = 10

# Allow specific violations in specific files (e.g., unused imports in __init__)
per-file-ignores =
    __init__.py: F401
    tests/*: S101
